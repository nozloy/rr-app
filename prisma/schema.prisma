generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  accounts      Account[]
  sessions      Session[]
  characters    Character[]
  raidCheckBookmarks RaidCheckBookmark[]
}

enum ActivityKind {
  RAID
  DUNGEON
  OPEN_WORLD
}

enum ActivityGroupKind {
  EXPANSION
  SEASON
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Character {
  id           String   @id @default(cuid())
  userId       String
  characterId  BigInt
  name         String
  realm        String
  realmSlug    String
  className    String
  raceName     String
  factionName  String
  level        Int
  activeSpec   String?
  itemLevel    Int
  thumbnailUrl String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([userId, isActive])
}

model WowCharacter {
  id             String    @id @default(cuid())
  name           String
  serverSlug     String
  serverRegion   String
  warcraftLogsId Int?
  lastFetchedAt  DateTime?
  rankingsJson   Json?
  gearJson       Json?
  averageParse   Float?
  bestParse      Float?
  raidStatsJson  Json?
  raiderIoProfileJson Json?
  raiderIoScore Float?
  raiderIoProfileUrl String?
  raiderIoFetchedAt DateTime?
  blizzardEquipmentJson Json?
  blizzardEquippedItemLevel Int?
  blizzardTopItemJson Json?
  blizzardEquipmentFetchedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([name, serverSlug, serverRegion])
  @@index([serverRegion, serverSlug])
}

model RaidCheckBookmark {
  id           String   @id @default(cuid())
  userId       String
  name         String
  realm        String?
  serverSlug   String
  serverRegion String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, serverSlug, serverRegion])
  @@index([userId, serverRegion, serverSlug])
}

model Activity {
  id                   String              @id @default(cuid())
  slug                 String              @unique
  kind                 ActivityKind
  nameRu               String
  nameEn               String
  shortNameRu          String
  shortNameEn          String
  artPath              String
  aliases              String[]            @default([])
  warcraftLogsZoneId   Int?
  warcraftLogsZoneName String?
  isActive             Boolean             @default(true)
  sortOrder            Int                 @default(0)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  groupItems           ActivityGroupItem[]

  @@index([kind, isActive, sortOrder])
}

model ActivityGroup {
  id        String              @id @default(cuid())
  slug      String              @unique
  kind      ActivityGroupKind
  nameRu    String
  nameEn    String
  startsAt  DateTime?
  endsAt    DateTime?
  isActive  Boolean             @default(true)
  sortOrder Int                 @default(0)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  items     ActivityGroupItem[]

  @@index([kind, isActive, sortOrder])
}

model ActivityGroupItem {
  id         String        @id @default(cuid())
  groupId    String
  activityId String
  sortOrder  Int           @default(0)
  createdAt  DateTime      @default(now())
  group      ActivityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  activity   Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@unique([groupId, activityId])
  @@index([activityId])
  @@index([groupId, sortOrder])
}

model EventDifficultyOption {
  id        String   @id @default(cuid())
  slug      String   @unique
  labelRu   String
  labelEn   String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}
