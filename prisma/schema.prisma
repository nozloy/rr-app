generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String      @id @default(cuid())
  name          String?
  email         String?     @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  accounts      Account[]
  sessions      Session[]
  characters    Character[]
  raidCheckBookmarks RaidCheckBookmark[]
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId, provider])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Character {
  id           String   @id @default(cuid())
  userId       String
  characterId  BigInt
  name         String
  realm        String
  realmSlug    String
  className    String
  raceName     String
  factionName  String
  level        Int
  activeSpec   String?
  itemLevel    Int
  thumbnailUrl String?
  avatarUrl    String?
  isActive     Boolean  @default(true)
  lastSyncedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([userId, isActive])
}

model WowCharacter {
  id             String    @id @default(cuid())
  name           String
  serverSlug     String
  serverRegion   String
  warcraftLogsId Int?
  lastFetchedAt  DateTime?
  rankingsJson   Json?
  gearJson       Json?
  averageParse   Float?
  bestParse      Float?
  raidStatsJson  Json?
  raiderIoProfileJson Json?
  raiderIoScore Float?
  raiderIoProfileUrl String?
  raiderIoFetchedAt DateTime?
  blizzardEquipmentJson Json?
  blizzardEquippedItemLevel Int?
  blizzardTopItemJson Json?
  blizzardEquipmentFetchedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([name, serverSlug, serverRegion])
  @@index([serverRegion, serverSlug])
}

model RaidCheckBookmark {
  id           String   @id @default(cuid())
  userId       String
  name         String
  realm        String?
  serverSlug   String
  serverRegion String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, serverSlug, serverRegion])
  @@index([userId, serverRegion, serverSlug])
}
